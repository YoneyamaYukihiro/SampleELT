<Window x:Class="BreezeFlow.Dialogs.RunHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="実行履歴"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel>

        <!-- ==================== フィルタバー ==================== -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 1 行目: 期間 + パイプライン名 + ボタン -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="期間" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker Grid.Row="0" Grid.Column="1" x:Name="FromDatePicker" Width="120" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="〜" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker Grid.Row="0" Grid.Column="3" x:Name="ToDatePicker"   Width="120" Margin="0,0,12,0"/>

                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="検索:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="SearchBox" Width="180" Height="24" Padding="4,2"
                             ToolTip="パイプライン名 / ファイルパス / ジョブ名に部分一致"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" Content="🔄 更新" Padding="10,4" Margin="4,0,0,0"
                            Click="RefreshButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>

                <!-- 2 行目: ステータス + トリガ チェックボックス -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="6" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="状態:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox x:Name="StatusSuccess"   Content="成功"     IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="StatusFailed"    Content="失敗"     IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="StatusCancelled" Content="キャンセル" IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="StatusRunning"   Content="実行中"   IsChecked="True" Margin="0,0,16,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>

                    <TextBlock Text="トリガ:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox x:Name="TrigManual"   Content="手動"       IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="TrigSchedule" Content="スケジュール" IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="TrigCli"      Content="CLI"        IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="TrigJob"      Content="ジョブ"     IsChecked="True" Margin="0,0,8,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== ボトムバー ==================== -->
        <Border DockPanel.Dock="Bottom" Background="#FAFAFA" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="8,6">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="ResultCountText" Text="" VerticalAlignment="Center" Foreground="#616161"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="OpenFileButton" Content="📂 ファイルを開く" Padding="10,4" Margin="0,0,6,0"
                            Click="OpenFileButton_Click"
                            ToolTip="メインウィンドウで該当パイプラインを開く"
                            IsEnabled="False"/>
                    <Button x:Name="DeleteButton"   Content="🗑 削除"          Padding="10,4" Margin="0,0,6,0"
                            Click="DeleteButton_Click"
                            ToolTip="選択中の実行履歴を削除"
                            IsEnabled="False"/>
                    <Button x:Name="VacuumButton"   Content="DB 最適化"       Padding="10,4" Margin="0,0,6,0"
                            Click="VacuumButton_Click"
                            ToolTip="VACUUM を実行して runs.db を圧縮"/>
                    <Button Content="閉じる" Padding="14,4" Click="Close_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ==================== メイン: 一覧 + 詳細 ==================== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" MinWidth="380"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"   MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- 左: 実行リスト -->
            <DataGrid x:Name="RunsGrid"
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionChanged="RunsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="状態" Binding="{Binding StatusIcon}" Width="40" FontFamily="Segoe UI Emoji"/>
                    <DataGridTextColumn Header="開始時刻" Binding="{Binding StartedAtDisplay}" Width="140" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="所要" Binding="{Binding DurationDisplay}" Width="70" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="トリガ" Binding="{Binding TriggerDisplay}" Width="80"/>
                    <DataGridTextColumn Header="パイプライン" Binding="{Binding DisplayName}" Width="*"/>
                    <DataGridTextColumn Header="行数" Binding="{Binding TotalRows}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

            <!-- 右: 選択中の詳細 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 詳細ヘッダ -->
                <Border Grid.Row="0" Background="#ECEFF1" Padding="10,8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <StackPanel x:Name="DetailHeaderPanel">
                        <TextBlock x:Name="DetailTitleText" Text="(選択なし)" FontWeight="Bold" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock x:Name="DetailSubText" Text="" FontSize="11" Foreground="#616161" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock x:Name="DetailErrorText" Text="" FontSize="11" Foreground="#C62828" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ステップ明細 -->
                <DataGrid x:Name="StepsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="状態" Binding="{Binding StatusIcon}" Width="40" FontFamily="Segoe UI Emoji"/>
                        <DataGridTextColumn Header="#"    Binding="{Binding StepOrder}" Width="32" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="ステップ名"   Binding="{Binding StepName}" Width="*"/>
                        <DataGridTextColumn Header="所要"   Binding="{Binding DurationDisplay}" Width="70" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="行数"   Binding="{Binding RowCount}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

                <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

                <!-- ログ -->
                <Border Grid.Row="3" Background="#263238">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ログ" Foreground="White" FontWeight="Bold"
                                   FontSize="11" Padding="8,4" Background="#37474F"/>
                        <ScrollViewer x:Name="LogsScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="LogsItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayLine}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Margin="8,1">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#B0BEC5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                            <Setter Property="Foreground" Value="#FF8A65"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                            <Setter Property="Foreground" Value="#FFD54F"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
