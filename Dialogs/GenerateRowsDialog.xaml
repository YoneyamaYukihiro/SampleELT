<Window x:Class="SampleELT.Dialogs.GenerateRowsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Rows 設定"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステップ名 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- 生成行数 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="生成行数" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="RowCountBox" Height="28" Padding="6,4" Width="100" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- フィールド定義 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,4">
            <TextBlock Text="フィールド定義" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="1行1フィールド。書式: フィールド名=デフォルト値" Foreground="#555555" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock Text="例:&#10;start_date=&#10;end_date=&#10;counter=1" Foreground="#777777" FontSize="10" Margin="0,0,0,4" FontFamily="Consolas"/>
        </StackPanel>
        <TextBox Grid.Row="3"
                 x:Name="FieldsBox"
                 Height="120"
                 Padding="6,4"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Margin="0,0,0,12"/>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,8,0"
                    Click="OK_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル" Width="80" Height="30" Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
