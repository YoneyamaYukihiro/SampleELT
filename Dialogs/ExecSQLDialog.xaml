<Window x:Class="SampleELT.Dialogs.ExecSQLDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exec SQL 設定"
        Width="760" Height="520"
        MinWidth="620" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- ステップ名 / 接続 (固定) -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- SQL (可変) -->
            <RowDefinition Height="*" MinHeight="120"/>
            <!-- 行ごとに実行 / ボタン (固定) -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステップ名 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- 接続選択 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="DB 接続" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ConnectionCombo"
                          Grid.Column="0" Height="28"
                          DisplayMemberPath="DisplayName"/>
                <Button Grid.Column="2"
                        Content="⚙ 接続設定管理"
                        Height="28" FontSize="11"
                        Click="ManageConnections_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Grid.Column="4"
                        Content="🔗 接続テスト"
                        Height="28" FontSize="11"
                        Click="TestConnection_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
            <TextBlock x:Name="NoConnectionHint"
                       Text="※ 接続が登録されていません。[接続設定管理] で追加してください。"
                       Foreground="#E53935" FontSize="11" Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- SQL (可変領域) -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SQL クエリ" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="※ SQL 欄をダブルクリックすると大きな画面で編集できます"
                           FontSize="11" Foreground="#777777"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
            <TextBox Grid.Row="1"
                     x:Name="SQLBox"
                     Padding="6,4"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#FAFAFA"
                     BorderBrush="#CCCCCC"
                     ToolTip="Tab でスペース 4 個挿入、Ctrl+Tab で次のコントロールへフォーカス移動、ダブルクリックで大きな画面で編集"
                     PreviewKeyDown="SQLBox_PreviewKeyDown"
                     MouseDoubleClick="SQLBox_MouseDoubleClick"/>
        </Grid>

        <!-- 行ごとに実行 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <CheckBox x:Name="ExecuteEachRowCheck"
                      Content="行ごとに実行（前ステップの各行の値を ? パラメータとして渡す）"
                      FontSize="11"/>
        </StackPanel>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    Click="OK_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル"
                    Width="80" Height="30"
                    Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#EEEEEE"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
        </StackPanel>
    </Grid>
</Window>
