<Window x:Class="SampleELT.Dialogs.DBOutputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DB Output 設定"
        Width="500" Height="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- DB Type -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="データベース種別" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox x:Name="DBTypeCombo" Height="28"
                      SelectionChanged="DBTypeCombo_SelectionChanged">
                <ComboBoxItem Content="Oracle" IsSelected="True"/>
                <ComboBoxItem Content="MySQL"/>
            </ComboBox>
        </StackPanel>

        <!-- Connection String -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="接続文字列 (Connection String)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="ConnectionStringBox"
                     Height="52"
                     Padding="6,4"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- Table Name -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="テーブル名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TableNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- Mode -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="書き込みモード" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox x:Name="ModeCombo" Height="28">
                <ComboBoxItem Content="INSERT" IsSelected="True"/>
                <ComboBoxItem Content="UPSERT"/>
            </ComboBox>
        </StackPanel>

        <!-- Test Connection -->
        <Button Grid.Row="5"
                Content="🔗 接続テスト"
                HorizontalAlignment="Left"
                Width="120"
                Height="30"
                Margin="0,0,0,10"
                Click="TestConnection_Click"
                Style="{StaticResource PrimaryButtonStyle}"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    Click="OK_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル"
                    Width="80" Height="30"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
