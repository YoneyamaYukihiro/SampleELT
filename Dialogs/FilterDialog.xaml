<Window x:Class="BreezeFlow.Dialogs.FilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter 設定"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- Field Name -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="フィールド名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="FieldNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- Operator -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="演算子" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox x:Name="OperatorCombo" Height="28"
                      SelectionChanged="OperatorCombo_SelectionChanged">
                <ComboBoxItem Content="equals"         ToolTip="フィールド値が「値」と等しい行を通過 (= 値)" IsSelected="True"/>
                <ComboBoxItem Content="notEquals"      ToolTip="フィールド値が「値」と等しくない行を通過 (≠ 値)"/>
                <ComboBoxItem Content="contains"       ToolTip="フィールド値に「値」を部分文字列として含む行を通過 (LIKE %値%)"/>
                <ComboBoxItem Content="greaterThan"    ToolTip="フィールド値が「値」より大きい行を通過 (&gt; 値)"/>
                <ComboBoxItem Content="greaterOrEqual" ToolTip="フィールド値が「値」以上の行を通過 (≥ 値)"/>
                <ComboBoxItem Content="lessThan"       ToolTip="フィールド値が「値」より小さい行を通過 (&lt; 値)"/>
                <ComboBoxItem Content="lessOrEqual"    ToolTip="フィールド値が「値」以下の行を通過 (≤ 値)"/>
                <ComboBoxItem Content="isNull"         ToolTip="フィールド値が NULL (空) の行のみ通過。「値」は使用しない"/>
                <ComboBoxItem Content="isNotNull"      ToolTip="フィールド値が NULL でない行のみ通過。「値」は使用しない"/>
            </ComboBox>
            <Border Background="#F5F5F5" CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                <TextBlock x:Name="OperatorDescription"
                           FontSize="11" Foreground="#424242"
                           TextWrapping="Wrap"
                           Text="フィールド値が「値」と等しい行を通過 (= 値)"/>
            </Border>
        </StackPanel>

        <!-- Value -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="値（リテラル）" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="ValueBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- Right Field -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="右辺フィールド名（フィールド比較）" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="RightFieldBox" Height="28" Padding="6,4"/>
            <TextBlock Text="※ 入力時は「値」より優先されます" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    Click="OK_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル"
                    Width="80" Height="30"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
