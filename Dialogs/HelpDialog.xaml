<Window x:Class="SampleELT.Dialogs.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ヘルプ"
        Width="720" Height="620"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <TabControl x:Name="HelpTabControl" SelectedIndex="0">
        <TabItem Header="使い方">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="UsageTextBox"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Meiryo UI, Yu Gothic UI, sans-serif"
                         FontSize="12"
                         TextWrapping="Wrap"
                         Padding="12"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="仕様書">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="SpecTextBox"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Meiryo UI, Yu Gothic UI, sans-serif"
                         FontSize="12"
                         TextWrapping="Wrap"
                         Padding="12"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
