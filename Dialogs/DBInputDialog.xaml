<Window x:Class="SampleELT.Dialogs.DBInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DB Input 設定"
        Width="760" Height="660"
        MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- ステップ名 / 接続 / テーブル（固定） -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- SQL + Splitter + プレビュー（可変） -->
            <RowDefinition Height="*"/>
            <!-- 下ボタン（固定） -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== ステップ名 ==================== -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- ==================== DB 接続 ==================== -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="DB 接続（Oracle / MySQL）" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ConnectionCombo" Grid.Column="0" Height="28"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ConnectionCombo_SelectionChanged"/>
                <Button Grid.Column="2" Content="⚙ 接続設定管理" Height="28" FontSize="11"
                        Click="ManageConnections_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Grid.Column="4" Content="🔗 接続テスト" Height="28" FontSize="11"
                        Click="TestConnection_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
            <TextBlock x:Name="NoConnectionHint"
                       Text="※ 接続が登録されていません。[接続設定管理] で追加してください。"
                       Foreground="#E53935" FontSize="11" Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- ==================== テーブル選択 / SQL 自動生成 ==================== -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="テーブル" FontWeight="Bold" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="2" x:Name="TableCombo" Height="28" IsEditable="True"
                      ToolTip="テーブル名を入力するか、↓一覧取得 で選択"/>
            <Button Grid.Column="4" x:Name="LoadTablesButton"
                    Content="↓ 一覧取得" Height="28" FontSize="11"
                    ToolTip="選択した接続のテーブル一覧を取得"
                    Click="LoadTables_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Grid.Column="6"
                    Content="→ SQL 自動生成" Height="28" FontSize="11"
                    ToolTip="テーブルを選択して SELECT * FROM を生成"
                    Click="GenerateSQL_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Setter Property="Background" Value="#FF9800"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E65100"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- ==================== SQL テキスト + プレビュー（可変領域） ==================== -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="80"/>   <!-- SQL textbox -->
                <RowDefinition Height="5"/>                   <!-- Splitter -->
                <RowDefinition Height="Auto"/>                <!-- Execute each row -->
                <RowDefinition Height="Auto"/>                <!-- Preview 操作バー -->
                <RowDefinition Height="3*" MinHeight="80"/>   <!-- Preview DataGrid -->
            </Grid.RowDefinitions>

            <!-- SQL エディタ -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SQL クエリ" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" x:Name="SQLBox"
                         Padding="6,4"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#FAFAFA"
                         BorderBrush="#CCCCCC"/>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="#DDDDDD" ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndCurrent"/>

            <!-- 行ごとに実行 -->
            <CheckBox Grid.Row="2" x:Name="ExecuteEachRowCheck" Margin="0,6,0,6"
                      Content="行ごとに実行（前ステップの各行の値を ? パラメータとして渡す）"
                      FontSize="11"/>

            <!-- プレビュー 操作バー -->
            <Border Grid.Row="3" Background="#F5F5F5" CornerRadius="4"
                    Padding="8,5" Margin="0,0,0,4"
                    BorderBrush="#DDDDDD" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="プレビュー: 最大"
                               FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="2" x:Name="LimitTextBox" Text="100"
                             Height="26" Padding="4,2"
                             VerticalContentAlignment="Center"
                             TextAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text=" 行" VerticalAlignment="Center" FontSize="12"/>
                    <Button Grid.Column="5" x:Name="PreviewButton"
                            Content="▶ 実行" Height="26" Padding="12,0" FontSize="11"
                            Click="PreviewButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <TextBlock Grid.Column="6" x:Name="PreviewStatusText"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               FontSize="11" Foreground="#555" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- プレビュー DataGrid -->
            <DataGrid Grid.Row="4" x:Name="PreviewGrid"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      RowHeaderWidth="0"
                      FontSize="11"
                      Background="White"
                      BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="#F9F9F9"
                      ColumnHeaderHeight="28"/>
        </Grid>

        <!-- ==================== 下ボタン ==================== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,8,0"
                    Click="OK_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル" Width="80" Height="30"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
