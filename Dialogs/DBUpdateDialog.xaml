<Window x:Class="SampleELT.Dialogs.DBUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DB Update 設定"
        Width="600" Height="520"
        MinWidth="500" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- ステップ名 -->
            <RowDefinition Height="Auto"/>  <!-- DB 接続 -->
            <RowDefinition Height="Auto"/>  <!-- テーブル名 -->
            <RowDefinition Height="*" MinHeight="120"/>  <!-- カラム DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- コミットサイズ -->
            <RowDefinition Height="Auto"/>  <!-- ボタン -->
        </Grid.RowDefinitions>

        <!-- ステップ名 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- 接続選択 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="DB 接続" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ConnectionCombo"
                          Grid.Column="0" Height="28"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ConnectionCombo_SelectionChanged"/>
                <Button Grid.Column="2"
                        Content="⚙ 接続設定管理"
                        Height="28" FontSize="11"
                        Click="ManageConnections_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
            <TextBlock x:Name="NoConnectionHint"
                       Text="※ 接続が登録されていません。[接続設定管理] で追加してください。"
                       Foreground="#E53935" FontSize="11" Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- テーブル名 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="テーブル名" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TableCombo" Grid.Column="0" Height="28"
                          IsEditable="True"
                          ToolTip="テーブル名を入力するか、↓一覧取得 で選択"/>
                <Button Grid.Column="2" x:Name="LoadTablesButton"
                        Content="↓ 一覧取得" Height="28" FontSize="11"
                        ToolTip="選択した接続のテーブル一覧を取得"
                        Click="LoadTables_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Grid.Column="4" x:Name="LoadColumnsButton"
                        Content="🔄 カラム取得" Height="28" FontSize="11"
                        ToolTip="テーブルのカラム一覧を取得してキー/更新フィールドをチェックで設定"
                        Click="LoadColumns_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </StackPanel>

        <!-- カラム選択 DataGrid -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="カラム選択（キーフィールド・更新フィールド）"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="ColumnStatusText"
                           Text="※ カラム取得ボタンで一覧を表示できます"
                           FontSize="11" Foreground="#777777" VerticalAlignment="Center"/>
            </Grid>
            <DataGrid Grid.Row="1"
                      x:Name="ColumnGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      RowHeaderWidth="0"
                      FontSize="12"
                      AlternatingRowBackground="#F9F9F9"
                      ColumnHeaderHeight="28">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="カラム名"
                                        Binding="{Binding ColumnName}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTemplateColumn Header="キー" Width="60" CanUserResize="False">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="キー" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsKey, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="更新" Width="60" CanUserResize="False">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="更新" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsUpdate, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- コミットサイズ -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="コミットサイズ（件数）" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CommitSizeBox" Grid.Column="0"
                         Height="28" Padding="6,4" Text="100"/>
                <TextBlock Grid.Column="1"
                           Text="件ごとにコミット（0 = 最後に一括コミット）"
                           FontSize="11" Foreground="#757575"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- ボタン -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="🔗 接続テスト"
                    Width="110" Height="30"
                    Click="TestConnection_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="OK"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        Click="OK_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="キャンセル"
                        Width="80" Height="30"
                        Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#EEEEEE"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
