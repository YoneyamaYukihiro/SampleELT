<Window x:Class="SampleELT.Dialogs.SetVariableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="変数セット 設定"
        Width="500" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステップ名 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- 日付フォーマット -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="日付フォーマット" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="DateFormatCombo" Grid.Column="0" Height="28" IsEditable="True">
                    <ComboBoxItem Content="yyyy/MM/dd" IsSelected="True"/>
                    <ComboBoxItem Content="yyyy-MM-dd"/>
                    <ComboBoxItem Content="yyyyMMdd"/>
                    <ComboBoxItem Content="yyyy/MM/dd HH:mm:ss"/>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="(日付式で使用)" VerticalAlignment="Center"
                           Foreground="#666" FontSize="11"/>
            </Grid>
        </StackPanel>

        <!-- フィールド定義 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="変数定義  (フィールド名=式　を1行1件で記述)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="FieldsBox"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas,Courier New"
                     FontSize="13"
                     Padding="6,4"
                     MinHeight="140"
                     Height="140"/>
        </StackPanel>

        <!-- 式のヒント -->
        <Border Grid.Row="3" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
            <TextBlock FontFamily="Consolas,Courier New" FontSize="11" Foreground="#555"
                       TextWrapping="Wrap"><Run Text="使用できる式:"/><LineBreak/>
<Run Text="  TODAY         … 今日"/>
<LineBreak/>
<Run Text="  YESTERDAY     … 昨日"/>
<LineBreak/>
<Run Text="  TODAY-7       … 7日前  (TODAY+N も可)"/>
<LineBreak/>
<Run Text="  MONTH_START   … 当月初日"/>
<LineBreak/>
<Run Text="  MONTH_END     … 当月末日"/>
<LineBreak/>
<Run Text="  YEAR_START    … 当年初日"/>
<LineBreak/>
<Run Text="  YEAR_END      … 当年末日"/>
<LineBreak/>
<Run Text="  NOW           … 現在日時"/>
<LineBreak/>
<Run Text="  その他        … そのまま文字列として使用"/>
</TextBlock>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,8,0"
                    Click="OK_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル" Width="80" Height="30" Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
