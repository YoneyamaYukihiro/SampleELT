<Window x:Class="SampleELT.Dialogs.ConnectionManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DB 接続設定マネージャー"
        Width="760"
        Height="640"
        MinWidth="620"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: 接続一覧 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="接続一覧" FontWeight="Bold" Margin="0,0,0,6"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0"
                             x:Name="ConnectionListBox"
                             SelectionChanged="ConnectionListBox_SelectionChanged"
                             BorderBrush="#CCCCCC" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Padding="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Top">
                        <Button Content="↑" Width="32" Height="32" Padding="0" FontSize="14"
                                ToolTip="選択中の接続を上へ移動"
                                Click="MoveUp_Click"/>
                        <Button Content="↓" Width="32" Height="32" Padding="0" FontSize="14" Margin="0,6,0,0"
                                ToolTip="選択中の接続を下へ移動"
                                Click="MoveDown_Click"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="＋ 追加" Width="90" Height="28"
                            Click="AddConnection_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="🗑 削除" Width="90" Height="28" Margin="8,0,0,0"
                            Click="DeleteConnection_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFEBEE"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#EF9A9A"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFCDD2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 右: 編集フォーム -->
            <Grid Grid.Column="2" x:Name="EditPanel" IsEnabled="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 接続名 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="接続名" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="ConnNameBox" Height="28" Padding="6,4"
                             TextChanged="EditField_Changed"/>
                </StackPanel>

                <!-- DB 種別 -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="DB 種別" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DbTypeCombo" Height="28"
                              SelectionChanged="DbTypeCombo_SelectionChanged">
                        <ComboBoxItem Content="🔶 Oracle" Tag="Oracle" IsSelected="True"/>
                        <ComboBoxItem Content="🐬 MySQL" Tag="MySQL"/>
                        <ComboBoxItem Content="🐘 PostgreSQL" Tag="PostgreSQL"/>
                        <ComboBoxItem Content="🟦 SQL Server" Tag="SqlServer"/>
                        <ComboBoxItem Content="🦭 MariaDB" Tag="MariaDB"/>
                        <ComboBoxItem Content="🪶 SQLite" Tag="Sqlite"/>
                    </ComboBox>
                </StackPanel>

                <!-- Oracle: 個別フィールド -->
                <StackPanel Grid.Row="2" x:Name="OracleSection" Margin="0,0,0,10">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="サーバー" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="OracleServerBox" Height="28" Padding="6,4"
                                     Text="localhost" TextChanged="EditField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ポート" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="OraclePortBox" Height="28" Padding="6,4"
                                     Text="1521" TextChanged="EditField_Changed"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="サービス名 / SID" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="OracleServiceBox" Height="28" Padding="6,4"
                                 Text="ORCL" TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="ユーザー名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="OracleUserBox" Height="28" Padding="6,4"
                                 TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="パスワード" FontWeight="Bold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="OraclePassBox" Height="28" Padding="6,4"
                                     PasswordChanged="EditField_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- PostgreSQL: 個別フィールド -->
                <StackPanel Grid.Row="3" x:Name="PostgreSQLSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="サーバー" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="PgServerBox" Height="28" Padding="6,4"
                                     Text="localhost" TextChanged="EditField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ポート" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="PgPortBox" Height="28" Padding="6,4"
                                     Text="5432" TextChanged="EditField_Changed"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="データベース名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="PgDatabaseBox" Height="28" Padding="6,4"
                                 TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="ユーザー名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="PgUserBox" Height="28" Padding="6,4"
                                 Text="postgres" TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="パスワード" FontWeight="Bold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PgPassBox" Height="28" Padding="6,4"
                                     PasswordChanged="EditField_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- MySQL: 個別フィールド -->
                <StackPanel Grid.Row="4" x:Name="MySQLSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="サーバー" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="MySQLServerBox" Height="28" Padding="6,4"
                                     Text="localhost" TextChanged="EditField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ポート" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="MySQLPortBox" Height="28" Padding="6,4"
                                     Text="3306" TextChanged="EditField_Changed"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="データベース名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="MySQLDatabaseBox" Height="28" Padding="6,4"
                                 TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="ユーザー名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="MySQLUserBox" Height="28" Padding="6,4"
                                 Text="root" TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="パスワード" FontWeight="Bold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="MySQLPassBox" Height="28" Padding="6,4"
                                     PasswordChanged="EditField_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- SQL Server: 個別フィールド -->
                <StackPanel Grid.Row="5" x:Name="SqlServerSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="サーバー" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="MssServerBox" Height="28" Padding="6,4"
                                     Text="localhost" TextChanged="EditField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ポート" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="MssPortBox" Height="28" Padding="6,4"
                                     Text="1433" TextChanged="EditField_Changed"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="データベース名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="MssDatabaseBox" Height="28" Padding="6,4"
                                 TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <CheckBox x:Name="MssIntegratedSecurityCheck" Content="Windows 認証を使用"
                                  Checked="EditField_Changed" Unchecked="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="ユーザー名" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="MssUserBox" Height="28" Padding="6,4"
                                 Text="sa" TextChanged="EditField_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="パスワード" FontWeight="Bold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="MssPassBox" Height="28" Padding="6,4"
                                     PasswordChanged="EditField_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- SQLite: 個別フィールド -->
                <StackPanel Grid.Row="6" x:Name="SqliteSection" Visibility="Collapsed">
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="データベースファイル" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="SqlitePathBox" Height="28" Padding="6,4"
                                     TextChanged="EditField_Changed"/>
                            <Button Grid.Column="1"
                                    Content="参照..." Width="80" Height="28"
                                    Margin="6,0,0,0"
                                    Click="SqliteBrowse_Click"/>
                        </Grid>
                        <TextBlock Text="※ ファイルが存在しない場合は自動で新規作成されます。"
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 接続テスト + 自動保存ヒント -->
                <Grid Grid.Row="7" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="🔗 接続テスト"
                            Width="120" Height="28"
                            Click="TestConnection_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <TextBlock Grid.Column="1"
                               Text="💡 入力は自動保存されます (別接続選択 / DB 種別変更 / ＋追加 / ダイアログを閉じる時)"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="11"
                               Foreground="#616161"
                               TextWrapping="Wrap"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- 閉じるボタン -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="閉じる" Width="80" Height="30"
                    Click="Close_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
