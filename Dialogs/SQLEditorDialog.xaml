<Window x:Class="SampleELT.Dialogs.SQLEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL クエリ エディタ"
        Width="960" Height="720"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ラベル -->
        <TextBlock Grid.Row="0" Text="SQL クエリ" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>

        <!-- バインド変数の説明とサンプル -->
        <Border Grid.Row="1" Background="#F0F4FF" CornerRadius="4"
                BorderBrush="#C5D8F8" BorderThickness="1"
                Padding="10,8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="【バインド変数の使い方】" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                <TextBlock FontSize="11" Foreground="#444444" Margin="0,0,0,4"
                           Text="前ステップのフィールド値を SQL に埋め込むには :{フィールド名} を使います。"/>
                <Border Background="#E8EEF8" CornerRadius="3" Padding="8,6" Margin="0,0,0,4">
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#1A237E" xml:space="preserve">WHERE dt      &gt;= :{start_date}
AND   dt      &lt;  :{end_date}
AND   status   =  :{status}
AND   user_id  =  :{user_id}</TextBlock>
                </Border>
                <TextBlock FontSize="11" Foreground="#555555" TextWrapping="Wrap"
                           Text="Set Variable ステップで start_date=YESTERDAY_START などをセットしてからこのステップに接続すると、パラメータが自動的にバインドされます。"/>
            </StackPanel>
        </Border>

        <!-- SQL エディタ -->
        <TextBox Grid.Row="2"
                 x:Name="SQLBox"
                 Padding="8,6"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Background="#FAFAFA"
                 BorderBrush="#CCCCCC"
                 VerticalContentAlignment="Top"/>

        <!-- 下ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OKButton" Content="OK" Width="80" Height="30" Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="キャンセル" Width="80" Height="30"
                    IsCancel="True"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#EEEEEE"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
