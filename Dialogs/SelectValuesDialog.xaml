<Window x:Class="SampleELT.Dialogs.SelectValuesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Values 設定"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステップ名 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ステップ名" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="StepNameBox" Height="28" Padding="6,4"/>
        </StackPanel>

        <!-- フィールドマッピング -->
        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <TextBlock Text="フィールドマッピング" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="11" Margin="0,0,0,6">
                1行1フィールド。リネームする場合は「元フィールド名=新フィールド名」。
                記述したフィールドのみ出力されます（未記述は除去）。
            </TextBlock>
        </StackPanel>
        <TextBox Grid.Row="2"
                 x:Name="MappingsBox"
                 Height="160"
                 Padding="6,4"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Margin="0,0,0,12"/>

        <!-- ボタン -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="OK"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        Click="OK_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="キャンセル"
                        Width="80" Height="30"
                        Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#EEEEEE"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
