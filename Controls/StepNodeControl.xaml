<UserControl x:Class="SampleELT.Controls.StepNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="140" Height="70"
             Cursor="SizeAll">
    <Border x:Name="RootBorder"
            Background="White"
            BorderBrush="#DDDDDD"
            BorderThickness="1.5"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        <Grid Margin="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <TextBlock Grid.Column="0"
                       x:Name="IconText"
                       Text="{Binding DisplayIcon}"
                       FontSize="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Text area -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="NameText"
                           Text="{Binding DisplayName}"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#212121"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding DisplayName}"/>
                <TextBlock x:Name="TypeText"
                           Text="{Binding TypeLabel}"
                           FontSize="11"
                           Foreground="#757575"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
