<UserControl x:Class="BreezeFlow.Controls.StepNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="SizeAll">
    <Grid>
        <!-- カード本体 (右18pxを出力ポート用に空ける) -->
        <Border x:Name="RootBorder"
                Margin="0,0,18,0"
                Background="White"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <!-- 既定: 灰色細枠 -->
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Style.Triggers>
                        <!-- 選択中: 青枠 -->
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderBrush" Value="#2196F3"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                        <!-- Production 接続を使うステップは赤枠で警告 (選択中でも安全側を優先) -->
                        <DataTrigger Binding="{Binding IsProductionConnection}" Value="True">
                            <Setter Property="BorderBrush" Value="#D32F2F"/>
                            <Setter Property="BorderThickness" Value="2.5"/>
                        </DataTrigger>
                        <!-- 接続未解決 (削除済み等) は赤色枠 + 警告色背景 -->
                        <DataTrigger Binding="{Binding HasUnresolvedConnection}" Value="True">
                            <Setter Property="BorderBrush" Value="#D32F2F"/>
                            <Setter Property="BorderThickness" Value="2.5"/>
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- アイコン -->
                <TextBlock Grid.Column="0"
                           x:Name="IconText"
                           Text="{Binding DisplayIcon}"
                           FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- 名前・種別・接続名 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="NameText"
                               Text="{Binding DisplayName}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#212121"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DisplayName}"/>
                    <TextBlock x:Name="TypeText"
                               Text="{Binding TypeLabel}"
                               FontSize="10"
                               Foreground="#757575"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ConnText"
                               Text="{Binding ConnectionLabel}"
                               FontSize="9"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding ConnectionLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#1565C0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionLabel}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStagingConnection}" Value="True">
                                        <Setter Property="Foreground" Value="#F57C00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProductionConnection}" Value="True">
                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- 接続未解決の警告バッジ -->
                    <TextBlock Text="⚠ 接続未解決"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="#D32F2F"
                               ToolTip="ConnectionId が指す接続設定が存在しません。接続マネージャで設定し直してください。">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUnresolvedConnection}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 接続先ハイライト枠 (接続ドラッグ中にターゲットとして表示) -->
        <Border x:Name="ConnectionTargetOverlay"
                Margin="0,0,18,0"
                BorderBrush="#4CAF50"
                BorderThickness="2.5"
                CornerRadius="8"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>

        <!-- 出力ポート (右端・OutputPorts を縦に均等配置) -->
        <ItemsControl x:Name="OutputPortsHost"
                      ItemsSource="{Binding OutputPorts}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Stretch"
                      Width="18">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="18" Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="9"
                            Cursor="Cross"
                            ToolTip="{Binding Label}"
                            Tag="{Binding Key}"
                            MouseLeftButtonDown="OutputPort_MouseLeftButtonDown"
                            MouseEnter="OutputPort_MouseEnter"
                            MouseLeave="OutputPort_MouseLeave">
                        <Border.Style>
                            <!-- 既定 (Key=="" の単一ポート) は従来通り青、特定の Key は色を変えて識別性を上げる -->
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2196F3"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Key}" Value="pass">
                                        <Setter Property="Background" Value="#43A047"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Key}" Value="fail">
                                        <Setter Property="Background" Value="#FB8C00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Key}" Value="default">
                                        <Setter Property="Background" Value="#9E9E9E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3" Color="#2196F3"/>
                        </Border.Effect>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 入力ポート (左端・接続ドラッグ中のみ強調表示) -->
        <Ellipse x:Name="InputPort"
                 Width="12" Height="12"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="-6,0,0,0"
                 Fill="White"
                 Stroke="#BDBDBD"
                 StrokeThickness="2"
                 Visibility="Collapsed"
                 IsHitTestVisible="False"/>

        <!-- リサイズグリップ (右下隅) -->
        <Path x:Name="ResizeGrip"
              Data="M 0,8 L 8,0 M 4,8 L 8,4"
              Stroke="#BDBDBD"
              StrokeThickness="1.5"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,20,2"
              Width="10" Height="10"
              Cursor="SizeNWSE"
              MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"/>
    </Grid>
</UserControl>
