<UserControl x:Class="SampleELT.Controls.StepNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="SizeAll">
    <Grid>
        <!-- カード本体 (右16pxを出力ポート用に空ける) -->
        <Border x:Name="RootBorder"
                Margin="0,0,18,0"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1.5"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- アイコン -->
                <TextBlock Grid.Column="0"
                           x:Name="IconText"
                           Text="{Binding DisplayIcon}"
                           FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- 名前・種別・接続名 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="NameText"
                               Text="{Binding DisplayName}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#212121"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DisplayName}"/>
                    <TextBlock x:Name="TypeText"
                               Text="{Binding TypeLabel}"
                               FontSize="10"
                               Foreground="#757575"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ConnText"
                               Text="{Binding ConnectionLabel}"
                               FontSize="9"
                               Foreground="#1565C0"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding ConnectionLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionLabel}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 接続先ハイライト枠 (接続ドラッグ中にターゲットとして表示) -->
        <Border x:Name="ConnectionTargetOverlay"
                Margin="0,0,18,0"
                BorderBrush="#4CAF50"
                BorderThickness="2.5"
                CornerRadius="8"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>

        <!-- 出力ポート (右端・常時表示) -->
        <Border x:Name="OutputPort"
                Width="18" Height="18"
                Background="#2196F3"
                CornerRadius="9"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,0,0"
                Cursor="Cross"
                ToolTip="ここからドラッグして次のステップへ接続"
                MouseLeftButtonDown="OutputPort_MouseLeftButtonDown"
                MouseEnter="OutputPort_MouseEnter"
                MouseLeave="OutputPort_MouseLeave">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3" Color="#2196F3"/>
            </Border.Effect>
        </Border>

        <!-- 入力ポート (左端・接続ドラッグ中のみ強調表示) -->
        <Ellipse x:Name="InputPort"
                 Width="12" Height="12"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="-6,0,0,0"
                 Fill="White"
                 Stroke="#BDBDBD"
                 StrokeThickness="2"
                 Visibility="Collapsed"
                 IsHitTestVisible="False"/>

        <!-- リサイズグリップ (右下隅) -->
        <Path x:Name="ResizeGrip"
              Data="M 0,8 L 8,0 M 4,8 L 8,4"
              Stroke="#BDBDBD"
              StrokeThickness="1.5"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,20,2"
              Width="10" Height="10"
              Cursor="SizeNWSE"
              MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"/>
    </Grid>
</UserControl>
