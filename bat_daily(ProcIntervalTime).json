        "ConnectionId": "edf2f0ae-6642-4cf4-880c-e8783f57e405",
        "SQL": "SELECT\n\t@i:=@i\u002B1 AS ROWNUM,\n\tA.LINE_ID,\n\tA.SB_ID,\n\tA.PD_ID,\n\tA.LOT_ID,\n\tA.OP_ID,\n\tA.STEP_ID,\n\tA.WP_ID,\n\tA.RECIPE_ID,\n\tA.PROC_START,\n\tA.PROC_END\nFROM\n\t (SELECT @i:=0) AS DUMMY,\n\tREAL_PROCESS_TIME A\nWHERE\n\tA.LINE_ID = \u0027H1\u0027\nAND\tA.SB_ID = \u00271A0\u0027\nAND A.PROC_END \u003E= ?\nAND A.PROC_END \u003C ?\nORDER BY\n\tA.WP_ID,\n\tA.PROC_END",
        "ExecuteEachRow": "false"
      }
    },
    {
