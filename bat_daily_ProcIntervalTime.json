      "settings": {
        "ConnectionId": "b1c2d3e4-f5a6-7890-abcd-ef1234567891",
        "SQL": "SELECT\n\t@i:=@i+1 AS ROWNUM,\n\tA.LINE_ID,\n\tA.SB_ID,\n\tA.PD_ID,\n\tA.LOT_ID,\n\tA.OP_ID,\n\tA.STEP_ID,\n\tA.WP_ID,\n\tA.RECIPE_ID,\n\tA.PROC_START,\n\tA.PROC_END\nFROM\n\t (SELECT @i:=0) AS DUMMY,\n\tREAL_PROCESS_TIME A\nWHERE\n\tA.LINE_ID = 'H1'\nAND\tA.SB_ID = '1A0'\nAND A.PROC_END >= ?\nAND A.PROC_END < ?\nORDER BY\n\tA.WP_ID,\n\tA.PROC_END",
        "ExecuteEachRow": "false"
      }
    },
    {
