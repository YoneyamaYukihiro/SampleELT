        "SQL": "SELECT\n\t@i:=@i+1 AS ROWNUM,\n\tA.WP_ID,\n\tA.LOT_ID AS PREVIOUS_LOT_ID,\n\tA.OP_ID AS PREVIOUS_OP_ID,\n\tA.STEP_ID AS PREVIOUS_STEP_ID,\n\tA.RECIPE_ID AS PREVIOUS_RECIPE_ID,\n\tA.PROC_START AS PREVIOUS_PROC_START,\n\tA.PROC_END AS PREVIOUS_PROC_END\nFROM\n\t (SELECT @i:=1) AS DUMMY,\n\tREAL_PROCESS_TIME A\nWHERE\n\tA.LINE_ID = 'H1'\nAND\tA.SB_ID = '1A0'\nAND A.PROC_END >= ?\nAND A.PROC_END < ?\nORDER BY\n\tA.WP_ID,\n\tA.PROC_END",
        "ExecuteEachRow": "false"
