<Window x:Class="SampleELT.MainWindow"
        KeyDown="Window_KeyDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SampleELT.Controls"
        xmlns:vm="clr-namespace:SampleELT.ViewModels"
        Title="SampleELT - ETL Designer"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RunPipelineCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedStepCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規(_N)" Command="{Binding NewPipelineCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="開く(_O)..." Command="{Binding LoadPipelineCommand}"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="保存(_S)..." Command="{Binding SavePipelineCommand}"
                          InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="実行(_R)">
                <MenuItem Header="実行(_E)" Command="{Binding RunPipelineCommand}"
                          InputGestureText="F5"/>
                <MenuItem Header="停止(_S)" Command="{Binding StopCommand}"/>
                <Separator/>
                <MenuItem Header="キャンバスをクリア" Command="{Binding ClearCanvasCommand}"/>
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <MenuItem Header="DB 接続設定(_C)..." Click="ConnectionManager_Click"/>
                <MenuItem Header="スケジュール管理(_S)..." Click="ScheduleManager_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="使い方(_U)..." Click="HelpUsage_Click"/>
                <MenuItem Header="仕様書(_S)..." Click="HelpSpec_Click"/>
                <Separator/>
                <MenuItem Header="バージョン情報" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Background="#F5F5F5" Padding="4,2">
            <Button ToolTip="新規パイプライン" Command="{Binding NewPipelineCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="8,4">
                <TextBlock Text="📄 新規"/>
            </Button>
            <Button ToolTip="パイプラインを開く" Command="{Binding LoadPipelineCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="8,4">
                <TextBlock Text="📂 開く"/>
            </Button>
            <Button ToolTip="パイプラインを保存" Command="{Binding SavePipelineCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="8,4">
                <TextBlock Text="💾 保存"/>
            </Button>
            <Separator/>
            <Button ToolTip="パイプラインを実行 (F5)" Command="{Binding RunPipelineCommand}"
                    Padding="8,4">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Text="▶ 実行"/>
            </Button>
            <Button ToolTip="実行を停止" Command="{Binding StopCommand}"
                    Padding="8,4">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Setter Property="Background" Value="#F44336"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Text="■ 停止"/>
            </Button>
            <Separator/>
            <Button ToolTip="キャンバスをクリア" Command="{Binding ClearCanvasCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="8,4">
                <TextBlock Text="🗑 クリア"/>
            </Button>
            <Separator/>
            <Button ToolTip="スケジュール管理" Command="{Binding OpenScheduleManagerCommand}"
                    Padding="8,4">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Setter Property="Background" Value="#7B1FA2"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A148C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Text="⏰ スケジュール"/>
            </Button>
        </ToolBar>

        <!-- Status Bar (bottom) -->
        <StatusBar DockPanel.Dock="Bottom" Background="#ECEFF1" Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Margin="4,0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="120" Height="14" IsIndeterminate="{Binding IsRunning}"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left palette panel -->
                <ColumnDefinition Width="180" MinWidth="140"/>
                <ColumnDefinition Width="4"/>
                <!-- Canvas area -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <!-- Right properties panel -->
                <ColumnDefinition Width="200" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- ==================== LEFT PALETTE PANEL ==================== -->
            <Border Grid.Column="0"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8">
                        <TextBlock Text="ステップパレット"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="#424242"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="ダブルクリックで追加"
                                   FontSize="10"
                                   Foreground="#9E9E9E"
                                   Margin="0,0,0,10"/>

                        <!-- Input Group -->
                        <Border Background="#E3F2FD" CornerRadius="4" Padding="6,4" Margin="0,0,0,6">
                            <TextBlock Text="Input" FontWeight="Bold" FontSize="12" Foreground="#1565C0"/>
                        </Border>
                        <Button Content="🔌 DB Input"
                                Tag="{x:Static vm:StepTypeHelper.DBInput}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加（Oracle / MySQL 自動判別）"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="📂 File Input"
                                Tag="{x:Static vm:StepTypeHelper.ExcelInput}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>

                        <!-- Output Group -->
                        <Border Background="#E8F5E9" CornerRadius="4" Padding="6,4" Margin="0,10,0,6">
                            <TextBlock Text="Output" FontWeight="Bold" FontSize="12" Foreground="#1B5E20"/>
                        </Border>
                        <Button Content="🔌 DB Output"
                                Tag="{x:Static vm:StepTypeHelper.DBOutput}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加（Oracle / MySQL 自動判別）"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="📄 File Output"
                                Tag="{x:Static vm:StepTypeHelper.ExcelOutput}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="🔄 Insert/Update"
                                Tag="{x:Static vm:StepTypeHelper.InsertUpdate}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="✏️ DB Update"
                                Tag="{x:Static vm:StepTypeHelper.DBUpdate}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>

                        <!-- Transform Group -->
                        <Border Background="#FFF3E0" CornerRadius="4" Padding="6,4" Margin="0,10,0,6">
                            <TextBlock Text="Transform" FontWeight="Bold" FontSize="12" Foreground="#E65100"/>
                        </Border>
                        <Button Content="🔍 Filter"
                                Tag="{x:Static vm:StepTypeHelper.Filter}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="🧮 Calculation"
                                Tag="{x:Static vm:StepTypeHelper.Calculation}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="📋 Select Values"
                                Tag="{x:Static vm:StepTypeHelper.SelectValues}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>

                        <!-- DB Operation Group -->
                        <Border Background="#FCE4EC" CornerRadius="4" Padding="6,4" Margin="0,10,0,6">
                            <TextBlock Text="DB Operation" FontWeight="Bold" FontSize="12" Foreground="#880E4F"/>
                        </Border>
                        <Button Content="🗑 DB Delete"
                                Tag="{x:Static vm:StepTypeHelper.DBDelete}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="⚡ Exec SQL"
                                Tag="{x:Static vm:StepTypeHelper.ExecSQL}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>

                        <!-- Utility Group -->
                        <Border Background="#EDE7F6" CornerRadius="4" Padding="6,4" Margin="0,10,0,6">
                            <TextBlock Text="Utility" FontWeight="Bold" FontSize="12" Foreground="#4527A0"/>
                        </Border>
                        <Button Content="🔢 Generate Rows"
                                Tag="{x:Static vm:StepTypeHelper.GenerateRows}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="🔗 Merge Join"
                                Tag="{x:Static vm:StepTypeHelper.MergeJoin}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="📅 Set Variable"
                                Tag="{x:Static vm:StepTypeHelper.SetVariable}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                        <Button Content="⬜ Dummy"
                                Tag="{x:Static vm:StepTypeHelper.Dummy}"
                                MouseDoubleClick="PaletteButton_DoubleClick"
                                ToolTip="ダブルクリックで追加"
                                Style="{StaticResource PaletteButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

            <!-- ==================== CANVAS + LOG AREA ==================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="150" MinHeight="80"/>
                </Grid.RowDefinitions>

                <!-- Canvas area -->
                <Border Grid.Row="0" Background="#ECEFF1" ClipToBounds="True">
                    <ScrollViewer x:Name="CanvasScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#ECEFF1">
                        <Grid>
                            <!-- Background canvas for mouse handling -->
                            <Canvas x:Name="BackgroundCanvas"
                                    Background="#ECEFF1"
                                    Width="2000" Height="1500"
                                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                    MouseMove="Canvas_MouseMove">

                                <!-- Connection lines layer -->
                                <ItemsControl x:Name="ConnectionsControl"
                                              ItemsSource="{Binding Connections}"
                                              IsHitTestVisible="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="2000" Height="1500"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Canvas>
                                                <!-- Arrow line -->
                                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                                      X2="{Binding X2}" Y2="{Binding Y2}"
                                                      Stroke="#2196F3" StrokeThickness="2"/>
                                                <!-- Arrowhead marker (simple) -->
                                                <Polygon Points="0,0 -10,-5 -10,5"
                                                         Fill="#2196F3"
                                                         RenderTransformOrigin="0,0">
                                                    <Polygon.RenderTransform>
                                                        <TransformGroup>
                                                            <RotateTransform Angle="{Binding ArrowAngle}"/>
                                                            <TranslateTransform X="{Binding X2}" Y="{Binding Y2}"/>
                                                        </TransformGroup>
                                                    </Polygon.RenderTransform>
                                                </Polygon>
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Temporary connection line (drawn during drag) -->
                                <Line x:Name="TempConnectionLine"
                                      Stroke="#FF9800" StrokeThickness="2"
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"
                                      IsHitTestVisible="False"/>

                                <!-- Step nodes layer -->
                                <ItemsControl x:Name="StepsControl"
                                              ItemsSource="{Binding Steps}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="2000" Height="1500"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:StepNodeControl
                                                x:Name="StepNode"
                                                DataContext="{Binding}"
                                                Width="{Binding NodeWidth}"
                                                Height="{Binding NodeHeight}"
                                                IsSelected="{Binding IsSelected}"
                                                IsConnectionTarget="{Binding IsConnectionTarget}"
                                                IsConnectingMode="{Binding IsConnectingMode}"
                                                MouseLeftButtonDown="StepNode_MouseLeftButtonDown"
                                                MouseLeftButtonUp="StepNode_MouseLeftButtonUp"
                                                MouseMove="StepNode_MouseMove"
                                                MouseRightButtonDown="StepNode_MouseRightButtonDown"
                                                OutputPortDragStarted="StepNode_OutputPortDragStarted"
                                                ResizeDragStarted="StepNode_ResizeDragStarted">
                                                <controls:StepNodeControl.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="⚙ 設定"
                                                                  Click="StepSettings_Click"
                                                                  Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="🗑 削除"
                                                                  Click="StepDelete_Click"
                                                                  Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </controls:StepNodeControl.ContextMenu>
                                            </controls:StepNodeControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <!-- Splitter between canvas and log -->
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

                <!-- Log panel -->
                <Border Grid.Row="2" Background="#263238">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#37474F" Padding="8,4">
                            <DockPanel>
                                <TextBlock Text="ログ" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                <Button DockPanel.Dock="Right"
                                        Content="クリア"
                                        HorizontalAlignment="Right"
                                        Padding="8,2"
                                        Height="22"
                                        FontSize="11"
                                        Click="ClearLog_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#546E7A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="3"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#78909C"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button DockPanel.Dock="Right"
                                        Content="📋 コピー"
                                        HorizontalAlignment="Right"
                                        Padding="8,2"
                                        Height="22"
                                        FontSize="11"
                                        Margin="0,0,4,0"
                                        Click="CopyLog_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#546E7A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="3"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#78909C"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DockPanel>
                        </Border>
                        <ScrollViewer x:Name="LogScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LogMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#B0BEC5"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Margin="8,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

            <!-- ==================== RIGHT SCHEDULE STATUS PANEL ==================== -->
            <Border Grid.Column="4"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1,0,0,0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#ECEFF1" Padding="8,5"
                            BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="📅 スケジュール" FontWeight="Bold" FontSize="13"
                                       Foreground="#424242" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="🔄"
                                    HorizontalAlignment="Right"
                                    ToolTip="一覧を更新"
                                    Click="RefreshSchedule_Click"
                                    Height="22" Padding="6,0" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Foreground" Value="#424242"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DockPanel>
                    </Border>
                    <!-- Schedule cards list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ScheduleStatusPanel" Margin="6,6"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
