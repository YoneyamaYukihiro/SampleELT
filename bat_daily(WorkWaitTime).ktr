    <jsScripts>      <jsScript>        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>&#47;&#47;日時の取得
var today = new Date();
var yesterday = new Date(); 
yesterday.setDate(yesterday.getDate()-1);

&#47;&#47;集計開始年月取得
var startYaer = yesterday.getYear() + 1900;
var startMonth = yesterday.getMonth() + 1;
var startDay = yesterday.getDate();

&#47;&#47;集計終了年月取得（当月）
var endYaer = today.getYear() + 1900;
var endMonth = today.getMonth() + 1;
var endDay = today.getDate();

var s = startYaer + &apos;&#47;&apos; + startMonth + &apos;&#47;&apos; + startDay;
var e = endYaer + &apos;&#47;&apos; + endMonth + &apos;&#47;&apos; + endDay;
&#47;&#47;var s = &quot;2026&#47;03&#47;22&quot;;
&#47;&#47;var e = &quot;2026&#47;03&#47;23&quot;;

start_date.setValue(s);
end_date.setValue(e);
</jsScript_script>
      </jsScript>    </jsScripts>    <fields>      <field>        <name>today</name>
