       <formula><field_name>WORK_WAIT_TIME_MIN</field_name>
<formula_string>([WORK_START]-[PREVIOUS_WORK_END])*24*60

</formula_string>
<value_type>Number</value_type>
<value_length>-1</value_length>
<value_precision>2</value_precision>
<replace_field/>
</formula>
