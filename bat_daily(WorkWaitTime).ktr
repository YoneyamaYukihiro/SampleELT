  <step>
    <name>SelectWpProcIntervalTime</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <copies>1</copies>
         <partitioning>
           <method>none</method>
           <schema_name/>
           </partitioning>
    <connection>Pcdt</connection>
    <sql>SELECT
	@i:=@i+1 AS ROWNUM,
	AA.*
FROM
	(SELECT @i:=0) AS DUMMY,
	(SELECT DISTINCT
		A.LINE_ID,
		A.SB_ID,
		A.PD_ID,
		A.LOT_ID,
		A.OP_ID,
		A.STEP_ID,
		A.WORK_START,
		A.WORK_END
	FROM
		REAL_PROCESS_TIME A,
		(
		SELECT
			LINE_ID,
			SB_ID,
			PD_ID,
			LOT_ID
		FROM
			REAL_PROCESS_TIME
		WHERE
			LINE_ID = &apos;H1&apos;
		AND	SB_ID = &apos;1A0&apos;
		AND	WORK_END &gt; ?
		AND	WORK_END &lt;= ?
		AND	LOT_FLOW_TYPE IS NULL
		GROUP BY
			LINE_ID, SB_ID, PD_ID, LOT_ID
		) B
	WHERE
		A.LINE_ID = B.LINE_ID
	AND	A.SB_ID = B.SB_ID
	AND	A.PD_ID = B.PD_ID
	AND	A.LOT_ID = B.LOT_ID
	ORDER BY
		LOT_ID,
		WORK_END
	) AA</sql>
    <limit>0</limit>
    <lookup>Select values</lookup>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
     <cluster_schema/>
