        "SQL": "SELECT\r\n\t@i:=@i+1 AS ROWNUM,\r\n\tAA.*,\r\n\t:{start_date} AS START_DATE_VAR,\r\n\t:{end_date} AS END_DATE_VAR\r\nFROM\r\n\t(SELECT @i:=1) AS DUMMY,\r\n\t(SELECT DISTINCT\r\n\t\tA.LINE_ID,\r\n\t\tA.SB_ID,\r\n\t\tA.PD_ID,\r\n\t\tA.LOT_ID,\r\n\t\tA.OP_ID AS PREVIOUS_OP_ID,\r\n\t\tA.STEP_ID AS PREVIOUS_STEP_ID,\r\n\t\tA.WORK_START AS PREVIOUS_WORK_START,\r\n\t\tA.WORK_END AS PREVIOUS_WORK_END\r\n\tFROM\r\n\t\tREAL_PROCESS_TIME A,\r\n\t\t(\r\n\t\tSELECT\r\n\t\t\tLINE_ID,\r\n\t\t\tSB_ID,\r\n\t\t\tPD_ID,\r\n\t\t\tLOT_ID\r\n\t\tFROM\r\n\t\t\tREAL_PROCESS_TIME\r\n\t\tWHERE\r\n\t\t\tLINE_ID = 'H1'\r\n\t\tAND\tSB_ID = '1A0'\r\n\t\tAND\tWORK_END > :{start_date}\r\n\t\tAND\tWORK_END <= :{end_date}\r\n\t\tAND\tLOT_FLOW_TYPE IS NULL\r\n\t\tGROUP BY\r\n\t\t\tLINE_ID, SB_ID, PD_ID, LOT_ID\r\n\t\t) B\r\n\tWHERE\r\n\t\tA.LINE_ID = B.LINE_ID\r\n\tAND\tA.SB_ID = B.SB_ID\r\n\tAND\tA.PD_ID = B.PD_ID\r\n\tAND\tA.LOT_ID = B.LOT_ID\r\n\tORDER BY\r\n\t\tLOT_ID,\r\n\t\tWORK_END\r\n\t) AA",
        "ExecuteEachRow": "false"
