  "Name": "bat_daily(WorkWaitTime)",
  "Steps": [
    {
      "Id": "7a1c5e4b-2f8d-4b0a-9c3e-1f6d8e2a5b71",
      "Name": "Set Variable",
      "StepType": "SetVariable",
      "CanvasX": 28,
      "CanvasY": 181,
      "NodeWidth": 150,
      "NodeHeight": 70,
      "Settings": {
        "Fields": "start_date = YESTERDAY\r\nend_date = TODAY",
