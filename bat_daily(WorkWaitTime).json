    },
    {
      "Id": "3b9f2a7d-6c1e-4d8a-bf52-9e3c7b1a4d68",
      "Name": "SelectWpProcIntervalTime",
      "StepType": "DBInput",
      "CanvasX": 201,
      "CanvasY": 132,
      "NodeWidth": 220,
      "NodeHeight": 80,
      "Settings": {
        "ConnectionId": "79297929-2eec-4f00-b85c-d4d6af0d8eb8",
        "SQL": "SELECT\r\n\t@i:=@i\u002B1 AS ROWNUM,\r\n\tAA.*\r\nFROM\r\n\t(SELECT @i:=0) AS DUMMY,\r\n\t(SELECT DISTINCT\r\n\t\tA.LINE_ID,\r\n\t\tA.SB_ID,\r\n\t\tA.PD_ID,\r\n\t\tA.LOT_ID,\r\n\t\tA.OP_ID,\r\n\t\tA.STEP_ID,\r\n\t\tA.WORK_START,\r\n\t\tA.WORK_END\r\n\tFROM\r\n\t\tREAL_PROCESS_TIME A,\r\n\t\t(\r\n\t\tSELECT\r\n\t\t\tLINE_ID,\r\n\t\t\tSB_ID,\r\n\t\t\tPD_ID,\r\n\t\t\tLOT_ID\r\n\t\tFROM\r\n\t\t\tREAL_PROCESS_TIME\r\n\t\tWHERE\r\n\t\t\tLINE_ID = \u0027H1\u0027\r\n\t\tAND\tSB_ID = \u00271A0\u0027\r\n\t\tAND\tWORK_END \u003E :{start_date}\r\n\t\tAND\tWORK_END \u003C= :{end_date}\r\n\t\tAND\tLOT_FLOW_TYPE IS NULL\r\n\t\tGROUP BY\r\n\t\t\tLINE_ID, SB_ID, PD_ID, LOT_ID\r\n\t\t) B\r\n\tWHERE\r\n\t\tA.LINE_ID = B.LINE_ID\r\n\tAND\tA.SB_ID = B.SB_ID\r\n\tAND\tA.PD_ID = B.PD_ID\r\n\tAND\tA.LOT_ID = B.LOT_ID\r\n\tORDER BY\r\n\t\tLOT_ID,\r\n\t\tWORK_END\r\n\t) AA",
        "ExecuteEachRow": "false"
      }
    },
    {
      "Id": "8d2f6b1e-7a3c-4e9d-bc14-5f8e2c7a3b69",
      "Name": "SelectWpProcIntervalTime 2",
      "StepType": "DBInput",
      "CanvasX": 197,
      "CanvasY": 228,
      "NodeWidth": 230,
      "NodeHeight": 80,
      "Settings": {
        "ConnectionId": "79297929-2eec-4f00-b85c-d4d6af0d8eb8",
        "SQL": "SELECT\r\n\t@i:=@i\u002B1 AS ROWNUM,\r\n\tAA.*\r\nFROM\r\n\t(SELECT @i:=1) AS DUMMY,\r\n\t(SELECT DISTINCT\r\n\t\tA.LINE_ID,\r\n\t\tA.SB_ID,\r\n\t\tA.PD_ID,\r\n\t\tA.LOT_ID,\r\n\t\tA.OP_ID AS PREVIOUS_OP_ID,\r\n\t\tA.STEP_ID AS PREVIOUS_STEP_ID,\r\n\t\tA.WORK_START AS PREVIOUS_WORK_START,\r\n\t\tA.WORK_END AS PREVIOUS_WORK_END\r\n\tFROM\r\n\t\tREAL_PROCESS_TIME A,\r\n\t\t(\r\n\t\tSELECT\r\n\t\t\tLINE_ID,\r\n\t\t\tSB_ID,\r\n\t\t\tPD_ID,\r\n\t\t\tLOT_ID\r\n\t\tFROM\r\n\t\t\tREAL_PROCESS_TIME\r\n\t\tWHERE\r\n\t\t\tLINE_ID = \u0027H1\u0027\r\n\t\tAND\tSB_ID = \u00271A0\u0027\r\n\t\tAND\tWORK_END \u003E :{start_date}\r\n\t\tAND\tWORK_END \u003C= :{end_date}\r\n\t\tAND\tLOT_FLOW_TYPE IS NULL\r\n\t\tGROUP BY\r\n\t\t\tLINE_ID, SB_ID, PD_ID, LOT_ID\r\n\t\t) B\r\n\tWHERE\r\n\t\tA.LINE_ID = B.LINE_ID\r\n\tAND\tA.SB_ID = B.SB_ID\r\n\tAND\tA.PD_ID = B.PD_ID\r\n\tAND\tA.LOT_ID = B.LOT_ID\r\n\tORDER BY\r\n\t\tLOT_ID,\r\n\t\tWORK_END\r\n\t) AA",
        "ExecuteEachRow": "false"
      }
    },
